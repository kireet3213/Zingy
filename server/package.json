{
    "name": "zingy-server",
    "version": "1.0.0",
    "description": "",
    "main": "index.js",
    "scripts": {
        "build": "tsc",
        "dev": "nodemon app.ts",
        "start": "pnpm build && cp .env ./dist && node ./dist/app.js",
        "migration:create": "ts-node database/commands/CreateMigration.ts",
        "check-types": "tsc -p tsconfig.json",
        "test": "echo \"Error: no test specified\" && exit 1",
        "migration:run": "ts-node database/commands/RunMigrations.ts",
        "lint": "eslint --config eslint.config.mjs",
        "seed": "ts-node database/commands/RunSeeders.ts",
        "migration:refresh": "ts-node database/commands/RefreshMigration.ts",
        "format": "pnpm prettier --write ."
    },
    "engines": {
        "npm": "use pnpm",
        "yarn": "use pnpm"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "bcrypt": "^6.0.0",
        "body-parser": "^2.2.2",
        "class-validator": "^0.15.1",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "express-session": "^1.19.0",
        "glob": "^13.0.6",
        "jsonwebtoken": "^9.0.3",
        "mysql2": "^3.18.2",
        "passport": "^0.7.0",
        "passport-local": "^1.0.0",
        "sequelize": "^6.37.7",
        "sequelize-typescript": "^2.1.6",
        "socket.io": "^4.8.3",
        "umzug": "3.8.2"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/bcrypt": "^6.0.0",
        "@types/body-parser": "^1.19.6",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/express-session": "^1.18.2",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^25.3.3",
        "@types/passport": "^1.0.17",
        "@types/passport-local": "^1.0.38",
        "@types/ws": "^8.18.1",
        "eslint": "~10.0.2",
        "globals": "^17.4.0",
        "nodemon": "^3.1.14",
        "prettier": "^3.8.1",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1"
    }
